import type { VideoData, VRSCriterion } from "./types";

// Instagram Reels Readiness Score (IRS): 20 criteria, 100 points total
// Formula: (DM_sends×0.40) + (Saves×0.30) + (3s_hold+Watch_time×0.30)
// Source: Mosseri-confirmed signal hierarchy (Jan/Feb 2025) + platform research

export const IG_CRITERIA: VRSCriterion[] = [
  // ─── TIER 1: Critical (50 points) ───

  {
    id: "ig-dm-send",
    label: "DM Send Potential",
    weight: 15,
    tier: 1,
    autoAssessable: true,
    check: (d: VideoData) => {
      // Proxy: high engagement + high share rate relative to views = DM send signal
      const shareRate = (d.shares ?? 0) / Math.max(1, d.views);
      const eng = d.engagement / 100;
      if (shareRate >= 0.01 || eng >= 0.06) return 1;
      if (shareRate >= 0.003 || eng >= 0.03) return 0.5;
      return 0;
    },
    rationale: (d: VideoData, score: number | null) => {
      const shareRate = ((d.shares ?? 0) / Math.max(1, d.views) * 100).toFixed(3);
      if (score === 1)
        return `Share rate ${shareRate}% + ${d.engagement.toFixed(1)}% engagement → strong DM send signal. Mosseri (Jan 2025) confirmed DM sends are the #1 signal for non-follower reach (~40% of distribution weight). This content is being actively forwarded.`;
      if (score === 0.5)
        return `Share rate ${shareRate}% → moderate DM send potential. To increase: add a specific "send this to [named recipient]" CTA — naming the recipient increases forward rate significantly over generic "share this."`;
      return `Share rate ${shareRate}% → weak DM send signal. DM sends carry ~40% of Instagram's distribution weight for unconnected reach. Content needs a shareable hook or utility moment that makes someone want to personally hand it to a specific person.`;
    },
  },
  {
    id: "ig-save-rate",
    label: "Save Rate (Reference Value)",
    weight: 13,
    tier: 1,
    autoAssessable: true,
    check: (d: VideoData) => {
      // Saves are 3× weight of a like on Instagram
      const saves = (d.saves ?? 0) / Math.max(1, d.views) * 100;
      if (saves >= 2) return 1;
      if (saves >= 0.5) return 0.5;
      // Proxy if saves not available: comment rate (people who save are engaged)
      const commentProxy = d.comments / Math.max(1, d.views) * 100;
      if (commentProxy >= 0.5) return 0.5;
      return 0;
    },
    rationale: (d: VideoData, score: number | null) => {
      const saves = ((d.saves ?? 0) / Math.max(1, d.views) * 100).toFixed(3);
      if (score === 1)
        return `Save rate ${saves}% → excellent. Saves are 3× the algorithmic weight of a like on Instagram. This content has reference value — people intend to return to it. Saves also extend shelf life: high-save Reels continue receiving "Suggested for you" impressions for 2–4 weeks beyond normal decay.`;
      if (score === 0.5)
        return `Save rate ${saves}% → moderate. To increase saves: embed a rule, number, formula, or checklist that's too dense to memorise in one watch. Close with "Save this before your next challenge" — save CTAs are the only type Instagram doesn't penalise.`;
      return `Save rate near 0% → missing a critical signal. Saves signal lasting utility to Instagram's algorithm. Content should include at least one piece of specific information — a number, rule, or formula — that viewers want to reference later.`;
    },
  },
  {
    id: "ig-3sec-hold",
    label: "3-Second Hold Rate (Hook Gate)",
    weight: 12,
    tier: 1,
    autoAssessable: true,
    check: (d: VideoData) => {
      // Proxy: velocity relative to channel median = engagement with cold audiences
      const velocity = d.velocity ?? 0;
      const eng = d.engagement / 100;
      // High velocity early = strong hook (people who saw it stayed)
      if (velocity >= 5000 && eng >= 0.04) return 1;
      if (velocity >= 1000 && eng >= 0.02) return 0.5;
      return 0;
    },
    rationale: (d: VideoData, score: number | null) => {
      const vel = (d.velocity ?? 0).toLocaleString();
      if (score === 1)
        return `Velocity ${vel} views/day + ${d.engagement.toFixed(1)}% engagement → strong 3-second hold signal. Instagram's kill threshold is 40% hold rate at 3 seconds. Below this = 5–10× less reach immediately. High velocity + engagement indicates the hook is clearing this gate with cold audiences.`;
      if (score === 0.5)
        return `Velocity ${vel} views/day → moderate hook performance. The hook must land before the caption overlay appears (~1.5 seconds). Test with Instagram's Trial Reels feature — it shows the 3-second hold rate on non-followers before committing to the main feed.`;
      return `Velocity ${vel} views/day → weak hook performance. The #1 cause of Instagram distribution failure. The visual hook must create surprise, curiosity, or utility recognition in under 1.5 seconds. Use Trial Reels to A/B test hooks before main-feed publishing.`;
    },
  },
  {
    id: "ig-watch-time",
    label: "Completion / Watch Time",
    weight: 10,
    tier: 1,
    autoAssessable: true,
    check: (d: VideoData) => {
      const eng = d.engagement / 100;
      const dur = d.durationSeconds;
      // For Reels: 7-15s optimal for punchy; 30-90s for educational
      const optimalDur = (dur >= 7 && dur <= 15) || (dur >= 30 && dur <= 90);
      if (eng >= 0.05 && optimalDur) return 1;
      if (eng >= 0.03 && dur >= 7) return 0.5;
      return 0;
    },
    rationale: (d: VideoData, score: number | null) => {
      const dur = d.durationSeconds;
      const durStr = dur < 60 ? `${dur}s` : `${Math.floor(dur/60)}m${dur%60}s`;
      if (score === 1)
        return `${d.engagement.toFixed(1)}% engagement + ${durStr} optimal duration → strong completion signal. Instagram requires ≥50% completion for Explore page eligibility. Strong engagement at optimal duration indicates viewers are watching through.`;
      if (score === 0.5)
        return `${d.engagement.toFixed(1)}% engagement, ${durStr} duration → moderate completion. Optimal lengths: 7–15s for pattern-interrupt content; 30–90s for educational value. Content outside these ranges needs exceptional hooks to maintain completion.`;
      return `${d.engagement.toFixed(1)}% engagement → weak completion signal. Below 50% completion = not eligible for Explore page. This is the minimum threshold for broader distribution. Tighten edit, move payoff earlier, or reduce duration.`;
    },
  },

  // ─── TIER 2: Strong Signals (30 points) ───

  {
    id: "ig-no-watermark",
    label: "No Third-Party Watermark",
    weight: 10,
    tier: 2,
    autoAssessable: false,
    check: (_d: VideoData) => null,
    rationale: (_d: VideoData, _score: number | null) =>
      "Cannot assess programmatically. Instagram runs pixel + audio fingerprinting on every upload. Any TikTok or CapCut watermark = automatic exclusion from recommendations. Zero exceptions. Always export a clean file from editing software before uploading.",
  },
  {
    id: "ig-originality",
    label: "Originality Score",
    weight: 8,
    tier: 2,
    autoAssessable: true,
    check: (d: VideoData) => {
      // Proxy: fresh content with recent upload + unique engagement patterns
      const recentDays = d.velocity != null && d.velocity > 100 ? 1 : 0;
      return recentDays ? 0.75 : 0.5; // Can't fully assess without IG internal data
    },
    rationale: (_d: VideoData, _score: number | null) =>
      "Instagram tracks originality at the account level. Accounts that repost ≥10 times in 30 days receive an account-level originality flag — this suppresses ALL content from that account including original videos published after the flag. Recovery takes 60–90 days. The only safe rule: never repost more than 10 times in any 30-day window.",
  },
  {
    id: "ig-engagement-quality",
    label: "Engagement Quality (Comments ≥5 words)",
    weight: 7,
    tier: 2,
    autoAssessable: true,
    check: (d: VideoData) => {
      const commentRate = d.comments / Math.max(1, d.views) * 100;
      if (commentRate >= 0.5) return 1;
      if (commentRate >= 0.2) return 0.5;
      return 0;
    },
    rationale: (d: VideoData, score: number | null) => {
      const rate = (d.comments / Math.max(1, d.views) * 100).toFixed(3);
      if (score === 1)
        return `Comment rate ${rate}% → strong. Meta's MSI (Meaningful Social Interaction) system scores comments ≥5 words at ~10× an emoji reaction. Substantive replies signal genuine engagement and improve distribution to similar audiences.`;
      if (score === 0.5)
        return `Comment rate ${rate}% → moderate. Ask a specific, easy-to-answer question in the caption. "What rule trips you up most in your challenge?" outperforms generic CTAs. Specific questions = specific (longer) answers.`;
      return `Comment rate ${rate}% → weak engagement depth. Instagram's algorithm reads comment quality, not count. Add a genuine question tied directly to the video content — not "What do you think?" but something specific that requires a real answer.`;
    },
  },
  {
    id: "ig-dual-signal",
    label: "Dual-Signal Moment (DM + Save in same content)",
    weight: 5,
    tier: 2,
    autoAssessable: false,
    check: (_d: VideoData) => null,
    rationale: (_d: VideoData, _score: number | null) =>
      "Cannot assess programmatically. The Instagram distribution holy grail: a single CTA that fires both DM sends AND saves simultaneously. Example: 'Save this formula — and send it to whoever you're doing a challenge with.' This is the highest algorithmic yield of any single CTA line on Instagram.",
  },

  // ─── TIER 3: Supporting Signals (15 points) ───

  {
    id: "ig-aspect-ratio",
    label: "Vertical Format (9:16)",
    weight: 5,
    tier: 3,
    autoAssessable: false,
    check: (_d: VideoData) => null,
    rationale: (_d: VideoData, _score: number | null) =>
      "Cannot assess from metadata. 9:16 is optimal. 4:5 is acceptable. 16:9 horizontal receives approximately 30% less reach in the Reels feed — vertical content fills the screen and gets more attention per frame.",
  },
  {
    id: "ig-hook-timing",
    label: "Visual Hook Before Caption Overlay (1.5s)",
    weight: 5,
    tier: 3,
    autoAssessable: false,
    check: (_d: VideoData) => null,
    rationale: (_d: VideoData, _score: number | null) =>
      "Cannot assess from metadata. Instagram's caption overlay appears at approximately 1.5 seconds. The visual hook must create a compelling reason to stay before the caption appears. This means the first 1.5 seconds must be entirely visual — a striking image, number, or action — before any text is processed by the viewer.",
  },
  {
    id: "ig-trial-reels",
    label: "Trial Reels Testing",
    weight: 5,
    tier: 3,
    autoAssessable: false,
    check: (_d: VideoData) => null,
    rationale: (_d: VideoData, _score: number | null) =>
      "Cannot assess from metadata. Trial Reels is Instagram's built-in A/B testing feature — it exposes your Reel to non-followers before committing to the main feed. It shows the 3-second hold rate from a cold audience. If hold rate is below 50% in Trial Reels, adjust the hook before main-feed publishing. This is the single most underused RM tool available for Instagram.",
  },

  // ─── TIER 4: Baseline Signals (5 points) ───

  {
    id: "ig-hashtag-quality",
    label: "Hashtag Strategy (5–10 mixed tiers)",
    weight: 3,
    tier: 4,
    autoAssessable: true,
    check: (d: VideoData) => {
      const tags = d.tags?.length ?? 0;
      if (tags >= 5 && tags <= 10) return 1;
      if (tags >= 3 && tags <= 15) return 0.5;
      if (tags > 0) return 0.25;
      return 0;
    },
    rationale: (d: VideoData, score: number | null) => {
      const tags = d.tags?.length ?? 0;
      if (score === 1)
        return `${tags} hashtags → optimal range. For Reels: 5–10 mixed hashtags (1–2 niche + 2–3 mid-range + 1–2 broad). Unlike feed posts, Reels don't rely heavily on hashtags for discovery — they're mainly for content classification.`;
      if (score === 0.5)
        return `${tags} hashtags → acceptable. Mix niche (#proptrading), mid-range (#forextrading), and broad (#investing) tags. Instagram's recommendation system uses hashtags for content classification, not primary discovery.`;
      return `${tags === 0 ? "No hashtags" : `${tags} hashtags`} → suboptimal. Include at least 3–5 hashtags for content classification. This affects how Instagram categorises the content for interest-matched distribution.`;
    },
  },
  {
    id: "ig-caption-quality",
    label: "Caption — Question or Save Trigger",
    weight: 2,
    tier: 4,
    autoAssessable: true,
    check: (d: VideoData) => {
      if (!d.title) return 0;
      const hasQuestion = /\?/.test(d.title);
      const hasSaveTrigger = /save|bookmark|write|remember|note/i.test(d.title);
      if (hasQuestion || hasSaveTrigger) return 1;
      if (d.title.length > 50) return 0.5;
      return 0.25;
    },
    rationale: (d: VideoData, _score: number | null) => {
      const hasQ = /\?/.test(d.title ?? "");
      const hasSave = /save|bookmark/i.test(d.title ?? "");
      if (hasQ || hasSave)
        return `Caption includes a ${hasQ ? "question" : "save trigger"} — effective engagement signal. For Reels: caption should either ask a specific question (drives comments) or include a save trigger ("save this before your next challenge"). Never use engagement bait.`;
      return `Caption doesn't include a question or save trigger. The caption should serve one of two purposes: (1) a specific question that requires a real answer, or (2) a save trigger that gives a reason to bookmark. Generic CTAs ("follow for more") are ignored.`;
    },
  },
];
